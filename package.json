{
  "name": "vision-benchmark",
  "version": "0.1.0",
  "description": "Deterministic synthetic benchmarks for vision-language models. Generate images with known ground truth, evaluate VLMs on how well they see.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vision-bench": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "bench:angle": "tsx src/cli.ts bench:angle",
    "bench:dots": "tsx src/cli.ts bench:dots",
    "list:models": "tsx src/cli.ts list:models",
    "list:datasets": "tsx src/cli.ts list:datasets",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vision",
    "benchmark",
    "vlm",
    "llm",
    "multimodal",
    "evaluation"
  ],
  "author": "Nicolas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolas/vision-benchmark.git"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "canvas": "^3.1.0",
    "commander": "^13.1.0",
    "puppeteer": "^24.41.0"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.2",
    "@types/node": "^22.13.0",
    "astro": "^6.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild"
    ]
  }
}
